---
import Base from '../layouts/Base.astro';
---

<Base title="Page not found · Harbor" description="That page doesn't exist.">
  <section class="hero hero-page">
    <div class="dotgrid hero-grid"></div>
    <div class="container hero-inner">
      <span class="eyebrow">404</span>
      <h1 class="hero-headline" style="font-size:56px;">Page not found.</h1>
      <p class="hero-paragraph">
        That page doesn't exist, or it moved. Head back to the homepage, or jump into the docs.
      </p>
      <div class="hero-cta-row">
        <a href="/" class="btn btn-primary btn-lg">Back home</a>
        <a href="/docs" class="btn btn-ghost btn-lg">Read the docs</a>
      </div>
    </div>
  </section>
</Base>
