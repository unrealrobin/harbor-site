# Resend — used by netlify/functions/subscribe.ts to add waitlist emails to an
# Audience. Set the real values in Netlify → Site settings → Environment
# variables. NEVER commit real values; this file documents the names only.

# API key from the Resend dashboard (Account → API Keys). Secret.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ID of the "Harbor Launch Notify" Audience (Resend → Audiences). Not secret,
# but kept in env so list changes don't require a code edit.
RESEND_AUDIENCE_ID=00000000-0000-0000-0000-000000000000

# PostHog — analytics snippet in src/layouts/Base.astro. The project key is a
# PUBLIC write-only ingest key (safe in client code), but kept in env as config.
# The snippet only renders on the Netlify production deploy (CONTEXT=production).
# Set POSTHOG_KEY in Netlify (Production context). POSTHOG_HOST is optional
# (defaults to US: https://us.i.posthog.com; use https://eu.i.posthog.com for EU).
POSTHOG_KEY=phc_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
POSTHOG_HOST=https://us.i.posthog.com
